 %% PawPal+ class design.
    %% Owner has 1..* Pets; each Pet has 0..* Tasks; Scheduler plans for an Owner.

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(name, pet_type) Pet
        +get_all_tasks() list~Task~
    }

    class Scheduler {
        +Owner owner
        +build_plan(sort_by, completed, pet_name) list~Task~
    }

    class Pet {
        +str name
        +str pet_type
        +list~Task~ tasks
        +Owner owner
        +find_conflicts(task) list~Task~
        +add_task(task) list~Task~
        +replace_conflicts(task) Task
        +get_tasks() list~Task~
    }

    class Task {
        +int time_start
        +str description
        +int duration_min
        +str priority
        +Pet pet
        +bool completed
        +str frequency
        +date date
        +mark_complete() Task
        +__lt__(other) bool
    }

    Owner "1" --> "1..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Pet "*" --> "1" Owner : belongs to
    Task "*" --> "1" Pet : belongs to
    Scheduler --> Owner : plans for