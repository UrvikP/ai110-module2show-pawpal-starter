classDiagram
    %% PawPal+ class design based on brainstorm.
    %% Owner has 1..* Pets; each Pet has 0..* Tasks.

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(name, pet_type) Pet
        +daily_plan(sort_by) list~Task~
    }

    class Pet {
        +str name
        +str pet_type
        +dict~str, Task~ tasks
        +add_task(task) None
        +get_tasks() list~Task~
    }

    class Task {
        +str time_start
        +str description
        +str duration
        +Priority priority
        +__lt__(other) bool
    }

    class Priority {
        <<enumeration>>
        HIGH
        MEDIUM
        LOW
    }

    Owner "1" --> "1..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Task --> Priority : uses
    